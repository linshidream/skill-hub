{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev-flow-state.schema.json",
  "title": ".dev-flow-state.json",
  "description": "开发流运行时状态文件的 JSON Schema",
  "type": "object",
  "required": ["phase", "reviews", "cascade"],
  "properties": {
    "phase": {
      "type": "string",
      "enum": [
        "not-started",
        "spec:intake",
        "spec:producing",
        "spec:awaiting-review",
        "spec:revising",
        "spec:approved",
        "branched",
        "step:developing",
        "step:awaiting-review",
        "step:revising",
        "step:approved",
        "code:developing",
        "code:awaiting-review",
        "code:revising",
        "code:approved",
        "pushed",
        "integrating",
        "integrated",
        "building",
        "deployed-test",
        "done"
      ],
      "description": "当前阶段"
    },
    "sub-phase": {
      "type": ["string", "null"],
      "default": null,
      "description": "子阶段（保留字段）"
    },
    "branch": {
      "type": ["string", "null"],
      "description": "当前 feature 分支名"
    },
    "developer": {
      "type": ["string", "null"],
      "description": "开发者标识"
    },
    "feature": {
      "type": ["string", "null"],
      "description": "功能 slug"
    },
    "spec": {
      "type": ["string", "null"],
      "description": "Spec 文件路径"
    },
    "spec-sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/spec-source" },
      "description": "Spec 使用的需求材料来源和证据摘要"
    },
    "implementation": {
      "type": "object",
      "properties": {
        "complexity": {
          "type": ["string", "null"],
          "enum": ["S", "M", "L", "XL", null],
          "description": "需求复杂度分级"
        },
        "mode": {
          "type": ["string", "null"],
          "enum": ["single-branch", null],
          "description": "V1 只支持 single-branch；step-branch/worktree 留作 V2"
        },
        "current-step": {
          "type": ["string", "null"],
          "description": "当前正在执行或等待 review 的 step id"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/implementation-step" }
        }
      },
      "description": "步骤化实施状态"
    },
    "started-at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "流程开始时间"
    },
    "reviews": {
      "type": "object",
      "properties": {
        "spec": { "$ref": "#/$defs/review-loop" },
        "code": { "$ref": "#/$defs/review-loop" }
      },
      "description": "Review Loop 状态"
    },
    "cascade": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean",
          "default": false
        },
        "type": {
          "type": ["string", "null"],
          "enum": ["after-spec-approved", "after-code-approved", null]
        },
        "steps-completed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps-remaining": {
          "type": "array",
          "items": { "type": "string" }
        },
        "interrupted-at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "interrupt-reason": {
          "type": ["string", "null"]
        }
      },
      "description": "Auto Cascade 状态"
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "hash": { "type": "string" },
          "message": { "type": "string" },
          "step": {
            "type": ["string", "null"],
            "description": "如果该 commit 属于某个 implementation step，记录 step id"
          },
          "timestamp": { "type": "string", "format": "date-time" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "提交记录"
    },
    "integration": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["merge-local", "pull-request"]
        },
        "attempted-at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "conflicts": {
          "type": ["object", "null"]
        },
        "resolved": {
          "type": "boolean",
          "default": false
        }
      },
      "description": "集成状态"
    },
    "build": {
      "type": "object",
      "properties": {
        "system": {
          "type": ["string", "null"],
          "enum": ["jenkins", null]
        },
        "number": {
          "type": ["integer", "null"]
        },
        "status": {
          "type": ["string", "null"],
          "enum": ["triggered", "building", "success", "failure", "aborted", "timeout", null]
        },
        "url": {
          "type": ["string", "null"],
          "description": "Masked URL or CI-relative build path. Do not persist raw credential-bearing URLs."
        }
      },
      "description": "CI 构建状态"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "event": { "type": "string" },
          "detail": { "type": "string" }
        }
      },
      "description": "关键事件时间线"
    }
  },
  "$defs": {
    "spec-source": {
      "type": "object",
      "required": ["id", "type", "location"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["user-description", "http-doc", "local-docx", "local-pdf", "local-markdown", "local-text", "image-prototype", "api-doc", "code-context", "other"]
        },
        "location": {
          "type": "string",
          "description": "URL、文件路径或 conversation/code reference；敏感 URL 必须脱敏"
        },
        "title": { "type": ["string", "null"] },
        "retrieved-at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "trust": {
          "type": ["string", "null"],
          "enum": ["confirmed", "inferred", "unverified", null]
        },
        "sensitive-handling": {
          "type": ["string", "null"],
          "enum": ["none", "redacted", "skipped-sensitive", null]
        },
        "summary": { "type": ["string", "null"] },
        "open-questions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "implementation-step": {
      "type": "object",
      "required": ["id", "title", "status"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "goal": { "type": ["string", "null"] },
        "status": {
          "type": "string",
          "enum": ["pending", "developing", "in_progress", "awaiting-review", "revising", "approved", "blocked"],
          "description": "`in_progress` is accepted as a legacy alias; new state should write `developing`."
        },
        "depends-on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested-scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk": {
          "oneOf": [
            {
              "type": ["string", "null"],
              "enum": ["low", "medium", "high", null]
            },
            {
              "type": "object",
              "properties": {
                "level": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                },
                "reason": { "type": ["string", "null"] }
              }
            }
          ]
        },
        "risk-reason": { "type": ["string", "null"] },
        "started-at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "finished-at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "files-changed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["passed", "failed", "skipped"]
              },
              "summary": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "review-loop": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not-started", "producing", "awaiting-review", "revising", "approved"]
        },
        "rounds": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "round": { "type": "integer" },
              "produced-at": { "type": ["string", "null"], "format": "date-time" },
              "review-started-at": { "type": ["string", "null"], "format": "date-time" },
              "feedback-at": { "type": ["string", "null"], "format": "date-time" },
              "approved-at": { "type": ["string", "null"], "format": "date-time" },
              "feedback-summary": { "type": ["string", "null"] },
              "files-changed": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "total-rounds": {
          "type": "integer",
          "default": 0
        },
        "approved-at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "total-review-duration": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
