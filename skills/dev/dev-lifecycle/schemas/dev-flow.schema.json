{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dev-flow.schema.json",
  "title": ".dev-flow.yml",
  "description": "项目开发流配置文件的 JSON Schema",
  "type": "object",
  "required": ["project", "developers", "branching"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "项目标识符"
        },
        "language": {
          "type": "string",
          "enum": ["java", "python", "node", "go", "rust", "kotlin"],
          "description": "项目语言"
        },
        "build-tool": {
          "type": "string",
          "enum": ["maven", "gradle", "npm", "pnpm", "yarn", "pip", "poetry", "go", "cargo"],
          "description": "构建工具"
        }
      }
    },
    "developers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "开发者姓名"
          }
        }
      },
      "description": "开发者列表，key 为缩写标识符"
    },
    "branching": {
      "type": "object",
      "required": ["production"],
      "properties": {
        "production": {
          "type": "string",
          "description": "生产分支"
        },
        "test": {
          "type": "string",
          "description": "测试分支"
        },
        "pattern": {
          "type": "string",
          "default": "feat/{developer}/{feature}",
          "description": "分支命名模式"
        }
      }
    },
    "integration": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["merge-local", "pull-request"],
          "default": "merge-local"
        },
        "conflict": {
          "type": "object",
          "properties": {
            "auto-resolve": {
              "type": "string",
              "enum": ["trivial", "none"],
              "default": "trivial"
            },
            "max-auto-files": {
              "type": "integer",
              "default": 3
            },
            "merge-tool": {
              "type": "string",
              "description": "Deprecated legacy field. Prefer gui-merge.enabled + gui-merge.tool. This field does not enable GUI merge by itself."
            },
            "gui-merge": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false,
                  "description": "GUI merge 是可选辅助能力，默认关闭；关闭或不可用时使用文本冲突流程"
                },
                "tool": {
                  "type": "string",
                  "default": "intellij",
                  "description": "启用 GUI merge 后使用的 Git mergetool 名称，默认 intellij"
                },
                "command": {
                  "type": "string",
                  "default": "idea",
                  "description": "本地命令行 launcher，intellij 默认检测 idea"
                },
                "fallback": {
                  "type": "string",
                  "enum": ["text"],
                  "default": "text",
                  "description": "GUI merge 不可用时自动降级到文本冲突流程"
                }
              }
            }
          }
        },
        "pull-request": {
          "type": "object",
          "properties": {
            "target": { "type": "string" },
            "draft": { "type": "boolean", "default": true },
            "reviewers": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string",
          "enum": ["jenkins"],
          "description": "V1 only implements Jenkins. Other CI systems should be added with adapters before being declared here."
        },
        "auto-trigger": {
          "type": "boolean",
          "default": true
        },
        "jenkins": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "job": { "type": "string" },
            "auth": {
              "type": "object",
              "properties": {
                "method": { "type": "string", "enum": ["token", "basic"] },
                "user": { "type": "string" },
                "token": { "type": "string" }
              }
            },
            "params": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "poll": {
              "type": "object",
              "properties": {
                "interval": { "type": "integer", "default": 30 },
                "timeout": { "type": "integer", "default": 1800 },
                "progress-log-lines": {
                  "type": "integer",
                  "default": 120,
                  "description": "长构建或失败时拉取 Jenkins consoleText 的尾部行数"
                },
                "fetch-log-on-failure": {
                  "type": "boolean",
                  "default": true,
                  "description": "构建失败后立即拉取日志并分析"
                }
              }
            }
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "properties": {
        "output-dir": {
          "type": "string",
          "default": "docs/specs"
        },
        "naming": {
          "type": "string",
          "default": "YYYYMMDD-{feature}.md"
        },
        "template": {
          "type": "string",
          "enum": ["default", "minimal", "api-integration"],
          "default": "default"
        },
        "required-sections": {
          "type": "array",
          "items": { "type": "string" }
        },
        "materials": {
          "type": "object",
          "properties": {
            "allow-http": {
              "type": "boolean",
              "default": true,
              "description": "允许读取用户提供的公网 HTTP/HTTPS 文档"
            },
            "allow-local-files": {
              "type": "boolean",
              "default": true,
              "description": "允许读取用户提供的本地 DOCX/PDF/Markdown/文本材料"
            },
            "allow-images": {
              "type": "boolean",
              "default": true,
              "description": "允许分析用户提供的原型图或截图"
            },
            "redact-sensitive": {
              "type": "boolean",
              "default": true,
              "description": "输出 spec 和 state 时必须脱敏敏感值"
            },
            "snapshot-dir": {
              "type": "string",
              "default": "docs/specs/_sources",
              "description": "材料摘要或 manifest 的建议存放目录"
            }
          }
        }
      }
    },
    "implementation": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["single-branch"],
          "default": "single-branch",
          "description": "V1 只支持 single-branch；step-branch/worktree 留作 V2"
        },
        "step-review": {
          "type": "string",
          "enum": ["per-step", "final-only"],
          "default": "per-step",
          "description": "是否对每个 implementation step 独立 review"
        },
        "max-steps-before-plan-review": {
          "type": "integer",
          "default": 6,
          "description": "超过该步骤数时，必须先让用户 review 实施计划"
        },
        "step-granularity": {
          "type": "string",
          "enum": ["business-slice", "technical-layer"],
          "default": "business-slice",
          "description": "V1 默认按业务闭环拆分；technical-layer 不推荐，仅显式配置时允许"
        },
        "max-steps-default": {
          "type": "integer",
          "default": 3,
          "description": "默认最多实施步骤数；超过时先请求用户确认"
        },
        "split-only-when": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["business-domain", "external-system", "risk-gate", "independent-acceptance"]
          },
          "default": ["business-domain", "external-system", "risk-gate", "independent-acceptance"]
        }
      }
    },
    "automation": {
      "type": "object",
      "properties": {
        "spec-confirm": {
          "type": "string",
          "enum": ["prompt", "quick"],
          "default": "prompt"
        },
        "completion-check": {
          "type": "string",
          "enum": ["manual", "auto"],
          "default": "manual"
        },
        "build-trigger": {
          "type": "string",
          "enum": ["auto", "confirm"],
          "default": "auto"
        },
        "review": {
          "type": "object",
          "properties": {
            "reminder": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "after": { "type": "string", "default": "4h" }
              }
            },
            "cascade": {
              "type": "object",
              "properties": {
                "after-spec-approved": {
                  "type": "array",
                  "items": { "type": "string" },
                  "default": ["git-flow:init"]
                },
                "after-code-approved": {
                  "type": "array",
                  "items": { "type": "string" },
                  "default": ["git-flow:commit", "git-flow:push", "git-flow:integrate", "ci-trigger:build"]
                }
              }
            },
            "cascade-interrupt": {
              "type": "object",
              "properties": {
                "on-conflict": {
                  "type": "string",
                  "enum": ["pause", "abort"],
                  "default": "pause"
                },
                "on-build-failure": {
                  "type": "string",
                  "enum": ["analyze-and-pause", "abort"],
                  "default": "analyze-and-pause"
                }
              }
            }
          }
        }
      }
    },
    "notify": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "on-build-success": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["channel"],
            "properties": {
              "channel": { "type": "string", "enum": ["dingtalk", "wechat-work", "feishu", "slack", "webhook"] },
              "webhook": {
                "type": "string",
                "description": "推荐使用 ${DINGTALK_WEBHOOK} 这类环境变量引用，不写明文 webhook"
              }
            }
          }
        },
        "on-build-failure": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["channel"],
            "properties": {
              "channel": { "type": "string", "enum": ["dingtalk", "wechat-work", "feishu", "slack", "webhook"] },
              "webhook": {
                "type": "string",
                "description": "推荐使用 ${DINGTALK_WEBHOOK} 这类环境变量引用，不写明文 webhook"
              }
            }
          }
        }
      }
    }
  }
}
